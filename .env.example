# Frontend: omit VITE_API_URL to use same-origin /api requests. Vite proxies
# local /api and /uploads requests to the backend on port 4000.
# VITE_API_URL="http://localhost:4000"

# Backend required secret (use a unique random value of at least 32 characters)
JWT_SECRET="replace-with-at-least-32-random-characters"

# Backend local defaults
NODE_ENV="development"
PORT="4000"
CORS_ORIGIN="http://localhost:8080"
MONGODB_URI="mongodb://127.0.0.1:27017"
MONGODB_DB_NAME="autoforge"
# false supports a normal standalone local MongoDB. Set true only for Atlas or a replica set.
MONGODB_TRANSACTIONS="false"
UPLOAD_DIR="backend/uploads"
MEDIA_STORAGE_DRIVER="local"
# Vercel Preview/Production use MEDIA_STORAGE_DRIVER="vercel-blob" and a
# project-scoped BLOB_READ_WRITE_TOKEN supplied by Vercel Storage.
# BLOB_READ_WRITE_TOKEN=""

# Authentication defaults
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_DAYS="7"
REMEMBER_ME_REFRESH_TOKEN_DAYS="30"
AUTH_COOKIE_NAME="autoforge_refresh"
AUTH_COOKIE_SAMESITE="lax"
AUTH_COOKIE_SECURE="false"
# Leave AUTH_COOKIE_DOMAIN unset for host-only cookies.

# Admin seed (required only for npm run seed:admin)
ADMIN_EMAIL="admin@autoforge.com"
ADMIN_PASSWORD="replace-with-a-strong-admin-password"
ADMIN_NAME="Store Administrator"

# Optional email delivery. If omitted, email sending is disabled.
# SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASS=""
# MAIL_FROM="noreply@example.com"

# Optional Razorpay checkout
# RAZORPAY_KEY_ID="rzp_test_..."
# RAZORPAY_KEY_SECRET=""
# GSTIN=""
