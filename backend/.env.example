# The canonical template is ../.env.example. Keep this file for users who
# discover the backend directory first, but copy the root template to ../.env.
MONGODB_URI="mongodb://127.0.0.1:27017"
MONGODB_DB_NAME="autoforge"
MONGODB_TRANSACTIONS="false"
JWT_SECRET="replace-with-at-least-32-random-characters"
CORS_ORIGIN="http://localhost:8080"
PORT="4000"
UPLOAD_DIR="backend/uploads"
MEDIA_STORAGE_DRIVER="local"
# BLOB_READ_WRITE_TOKEN is required with MEDIA_STORAGE_DRIVER="vercel-blob".
