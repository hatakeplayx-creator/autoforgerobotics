{
  "name": "tanstack_start_ts",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "node ./node_modules/vite/bin/vite.js build",
    "vercel-build": "npm run build",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "start": "node .output/server/index.mjs",
    "api:dev": "tsx backend/src/server.ts",
    "api:start": "node backend/dist/src/server.js",
    "api:build": "tsc -p backend/tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc -p backend/tsconfig.json && tsc -p server/tsconfig.json",
    "check": "npm run typecheck && npm run lint && npm run build",
    "prisma:seed": "tsx backend/prisma/seed.ts",
    "prisma:seed-admin": "tsx backend/prisma/seed-admin.ts",
    "seed:admin": "tsx backend/prisma/seed-admin.ts",
    "prisma:import-original-catalog": "tsx backend/prisma/import-original-catalog.ts",
    "prisma:map-original-categories": "tsx backend/prisma/map-original-product-categories.ts",
    "prisma:generate": "prisma generate --schema backend/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema backend/prisma/schema.prisma",
    "mongodb:migrate": "tsx backend/scripts/migrate-postgres-to-mongodb.ts",
    "mongodb:migrate:dry-run": "tsx backend/scripts/migrate-postgres-to-mongodb.ts --dry-run",
    "mongodb:verify": "tsx backend/scripts/migrate-postgres-to-mongodb.ts --verify-only",
    "mongodb:source-counts": "tsx backend/scripts/count-postgres-records.ts",
    "mongodb:seed": "tsx backend/scripts/seed-mongodb.ts",
    "media:migrate:cloudinary": "tsx backend/scripts/migrate-media-to-cloudinary.ts",
    "media:verify:cloudinary": "tsx backend/scripts/migrate-media-to-cloudinary.ts --verify-only",
    "test:media": "tsx --test backend/src/media/*.test.ts",
    "test:media:integration": "tsx backend/scripts/qa-media-local.ts",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
