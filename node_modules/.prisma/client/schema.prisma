generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum InventoryAction {
  RECEIVED
  ADJUSTMENT
  ORDER_CANCELLED
  ORDER_PLACED
  MARKED_OUT_OF_STOCK
}

enum EnquiryStatus {
  NEW
  CONTACTED
  APPROVED
  REJECTED
  ON_HOLD
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentProvider {
  RAZORPAY
}

enum ShippingProvider {
  SHIPROCKET
  DELHIVERY
  BLUEDART
  DTDC
}

enum ShipmentStatus {
  PENDING
  PICKED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  passwordHash   String?
  name           String
  phone          String?         @unique
  role           Role            @default(CUSTOMER)
  orders         Order[]
  addresses      Address[]
  refreshTokens  RefreshToken[]
  passwordResets PasswordReset[]
  otps           OTP[]
  reviews        ProductReview[]
  cartItems      CartItem[]
  wishlistItems  WishlistItem[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model OTP {
  id        String    @id @default(cuid())
  phone     String
  otp       String
  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  attempts  Int       @default(0)
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
}

model PasswordReset {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model Address {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  line1          String
  line2          String?
  city           String
  state          String
  postalCode     String
  country        String
  billingOrders  Order[]  @relation("OrderBillingAddress")
  shippingOrders Order[]  @relation("OrderShippingAddress")
  createdAt      DateTime @default(now())
}

model Media {
  id             String               @id @default(cuid())
  key            String               @unique
  url            String
  filename       String
  mimeType       String
  size           Int
  altText        String?
  categoryImages Category[]
  productImages  ProductImage[]
  reviewImages   ProductReviewImage[]
  createdAt      DateTime             @default(now())
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  imageId   String?
  image     Media?    @relation(fields: [imageId], references: [id], onDelete: SetNull)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id                 String              @id @default(cuid())
  name               String
  slug               String              @unique
  sku                String              @unique
  description        String?             @db.Text
  specifications     Json?
  brand              String?             @db.VarChar(120)
  price              Decimal             @db.Decimal(12, 2)
  compareAtPrice     Decimal?            @db.Decimal(12, 2)
  stockQuantity      Int                 @default(0)
  lowStockThreshold  Int                 @default(5)
  featured           Boolean             @default(false)
  categoryId         String?
  category           Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  images             ProductImage[]
  orderItems         OrderItem[]
  inventoryMovements InventoryMovement[]
  reviews            ProductReview[]
  cartItems          CartItem[]
  wishlistItems      WishlistItem[]
  hsnCode            String?
  gstPercentage      Decimal             @default(18) @db.Decimal(5, 2)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  mediaId   String
  media     Media   @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  sortOrder Int     @default(0)

  @@unique([productId, mediaId])
}

model ProductReview {
  id           String               @id @default(cuid())
  productId    String
  product      Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId       String
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderItemId  String?              @unique
  orderItem    OrderItem?           @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  rating       Int
  title        String?
  description  String?
  approved     Boolean              @default(false)
  helpfulVotes Int                  @default(0)
  reported     Boolean              @default(false)
  adminReply   String?
  images       ProductReviewImage[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}

model ProductReviewImage {
  id        String        @id @default(cuid())
  reviewId  String
  review    ProductReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  mediaId   String
  media     Media         @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  sortOrder Int           @default(0)

  @@unique([reviewId, mediaId])
}

model InventoryMovement {
  id            String          @id @default(cuid())
  productId     String
  product       Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  delta         Int
  quantityAfter Int
  action        InventoryAction
  note          String?
  createdAt     DateTime        @default(now())
}

model Order {
  id                String      @id @default(cuid())
  number            String      @unique
  userId            String
  user              User        @relation(fields: [userId], references: [id])
  status            OrderStatus @default(PENDING)
  subtotal          Decimal     @db.Decimal(12, 2)
  tax               Decimal     @default(0) @db.Decimal(12, 2)
  shipping          Decimal     @default(0) @db.Decimal(12, 2)
  total             Decimal     @db.Decimal(12, 2)
  billingAddressId  String?
  shippingAddressId String?
  billingAddress    Address?    @relation("OrderBillingAddress", fields: [billingAddressId], references: [id], onDelete: SetNull)
  shippingAddress   Address?    @relation("OrderShippingAddress", fields: [shippingAddressId], references: [id], onDelete: SetNull)
  payment           Payment?
  shipment          Shipment?
  invoice           Invoice?
  items             OrderItem[]
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  paidAt            DateTime?
  confirmedAt       DateTime?
}

model OrderItem {
  id            String         @id @default(cuid())
  orderId       String
  order         Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId     String?
  product       Product?       @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName   String
  sku           String
  quantity      Int
  unitPrice     Decimal        @db.Decimal(12, 2)
  hsnCode       String?
  gstPercentage Decimal        @default(18) @db.Decimal(5, 2)
  review        ProductReview?
  createdAt     DateTime       @default(now())
}

model Payment {
  id                String          @id @default(cuid())
  orderId           String          @unique
  order             Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider          PaymentProvider @default(RAZORPAY)
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  transactionId     String?
  amount            Decimal         @db.Decimal(12, 2)
  status            PaymentStatus   @default(PENDING)
  failureReason     String?
  paymentMethod     String?
  transactionTime   DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model RazorpayWebhookEvent {
  id          String   @id @default(cuid())
  eventId     String   @unique
  eventType   String
  payload     Json
  processedAt DateTime @default(now())
}

model Shipment {
  id                String            @id @default(cuid())
  orderId           String            @unique
  order             Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider          ShippingProvider?
  awbNumber         String?
  trackingNumber    String?
  courierName       String?
  estimatedDelivery DateTime?
  status            ShipmentStatus    @default(PENDING)
  labelUrl          String?
  trackingUrl       String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model Invoice {
  id            String   @id @default(cuid())
  number        String   @unique
  orderId       String   @unique
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  invoiceDate   DateTime @default(now())
  gstin         String
  customerGstin String?
  totalAmount   Decimal  @db.Decimal(12, 2)
  cgst          Decimal  @db.Decimal(12, 2)
  sgst          Decimal  @db.Decimal(12, 2)
  igst          Decimal  @db.Decimal(12, 2)
  pdfUrl        String?
  createdAt     DateTime @default(now())
}

model HomepageBlock {
  id        String   @id @default(cuid())
  key       String   @unique
  content   Json
  updatedAt DateTime @updatedAt
}

model BrandCollaboration {
  id        String   @id @default(cuid())
  name      String   @unique
  logoUrl   String
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model Enquiry {
  id          String        @id @default(cuid())
  type        String
  name        String
  email       String
  phone       String?
  companyName String?
  status      EnquiryStatus @default(NEW)
  details     Json?
  message     String        @db.Text
  notes       EnquiryNote[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model EnquiryNote {
  id        String   @id @default(cuid())
  enquiryId String
  enquiry   Enquiry  @relation(fields: [enquiryId], references: [id], onDelete: Cascade)
  body      String   @db.Text
  createdAt DateTime @default(now())
}
